# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection Strings
# For local development (if using local MongoDB)
MONGO_URI_LOCAL=mongodb://localhost:27017/es-runaba-db

# For production (MongoDB Atlas or your cloud database)
MONGO_URI_PRODUCTION=mongodb+srv://username:password@cluster.mongodb.net/es-runaba-db?retryWrites=true&w=majority

# Fallback: If you use a single MONGO_URI for both environments
# MONGO_URI=your_mongodb_connection_string

# JWT Secret for authentication
JWT_SECRET=change_this_secret_key_to_something_secure
